# Copy to .env to override defaults locally. Real environment variables take
# precedence over values set here.

# HTTP listen port for cmd/api. Default: 4523.
PORT=4523

# SQLite database file, shared by cmd/api and cmd/mcp. Use an absolute or
# CWD-relative path; ~ is not expanded. Default: ~/.projectmanager/projectmanager.db.
# (PM_DB_PATH is still honored as a legacy alias; DB_PATH wins if both are set.)
DB_PATH=./dev.db
